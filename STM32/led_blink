#include<stdint.h>
#define RCC_AHB1ENR (*(volatile uint32_t*)0x40023830)
#define GPIOD_MODER (*(volatile uint32_t*)0x40020C00)
#define GPIOD_ODR (*(volatile uint32_t*)0x40020C14)
void delay(){
	for(int i=0;i<500000;i++);
}
int main(void){
	RCC_AHB1ENR |=(1<<3);
	GPIOD_MODER &= ~(3<<26);
	GPIOD_MODER |=(1<<26);
while(1){
	GPIOD_ODR |=(1<<13);
	delay();
	GPIOD_ODR &= ~(1<<13);
	delay();
}
}
